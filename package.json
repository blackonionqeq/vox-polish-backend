{
  "name": "glossary-management",
  "version": "0.1.0",
  "private": true,
  "description": "Import genshin glossary JSON into PostgreSQL",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "llm:transcript": "tsx scripts/llm-transcipt.ts",
    "llm:transcript:debug": "tsx scripts/llm-transcript-debug.js",
    "import:words": "tsx scripts/import_genshin_words.ts --json genshin_words.json",
    "import:words:prune": "tsx scripts/import_genshin_words.ts --json genshin_words.json --prune"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/pg": "^8.16.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a"
}
