{
  "name": "glossary-management",
  "version": "0.1.0",
  "private": true,
  "description": "Import genshin glossary JSON into PostgreSQL",
  "type": "module",
  "scripts": {
    "dev": "tsx src/app/server.ts",
    "llm:transcript": "tsx scripts/llm/transcript.ts",
    "llm:transcript:debug": "tsx scripts/llm/transcript-debug.js",
    "llm:proofreading": "tsx scripts/llm/proofreading.ts",
    "import:words": "tsx scripts/data/import_genshin_words.ts --json genshin_words.json",
    "import:words:prune": "tsx scripts/data/import_genshin_words.ts --json genshin_words.json --prune"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/pg": "^8.16.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
